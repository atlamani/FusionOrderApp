rules_version = '3';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Customer orders remain accessible to their owner, while authenticated
    // staff/admin prototype sessions can also read and update order workflow data.
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() &&
        (
          resource == null ||
          resource.data.userId == request.auth.uid ||
          resource.data.userId == null
        );
      allow update: if isSignedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.userId == null
        );
      allow delete: if false;
    }

    // Backward compatibility for older docs written with capitalized collection name.
    match /Orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() &&
        (
          resource == null ||
          resource.data.userId == request.auth.uid ||
          resource.data.userId == null
        );
      allow update: if isSignedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.userId == null
        );
      allow delete: if false;
    }

    // Allow authenticated users to read/write their own user profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /Users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Admin prototype collections
    match /adminRestaurants/{restaurantId} {
      allow read, write: if isSignedIn();
    }

    match /adminFeedback/{feedbackId} {
      allow read, write: if isSignedIn();
    }

    match /drivers/{driverId} {
      allow read, write: if isSignedIn();
    }

    // Allow reading restaurants (public data)
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Allow reading menu items (public data)
    match /menu/{menuId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
